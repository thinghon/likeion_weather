# OpenWeather API 키 — 서버 전용. 실제 키는 .env 에 넣고 절대 커밋하지 마세요.
OPENWEATHERMAP_API_KEY=your_openweather_api_key

# Django SECRET_KEY — 반드시 각자 발급/생성해서 넣으세요 (git에 올리면 안 됨).
# 생성 예: python -c "import secrets,string; c=string.ascii_letters+string.digits+'!@#$%^&*(-_=+)'; print(''.join(secrets.choice(c) for _ in range(50)))"
DJANGO_SECRET_KEY=replace_with_your_own_secret_key

# 로컬 개발에서만 True로. 운영 배포 시에는 반드시 False(또는 미설정).
DJANGO_DEBUG=True

# 콤마로 구분한 허용 호스트 목록. 운영에서는 실제 도메인을 지정하세요.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# 콤마로 구분한 프론트엔드 CORS 허용 origin 목록.
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
